/*
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; manifest-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests
  Permissions-Policy: serial=(self), usb=(), geolocation=(), camera=(), microphone=(), payment=(), fullscreen=(self)
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=15552000

/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/firmware/*
  Cache-Control: public, max-age=31536000, immutable
